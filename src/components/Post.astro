---
const { title, description } = Astro.props;
---

<article class="group">
  <div
    class="post-card relative flex flex-col h-full backdrop-blur-md p-6 rounded-2xl shadow-xl border transition-all duration-300 hover:-translate-y-1 overflow-hidden"
  >
    <div
      class="absolute -top-24 -right-24 w-48 h-48 rounded-full blur-3xl"
      style="background: var(--card-glow)"
    >
    </div>
    <div class="relative z-10">
      <h2
        class="text-xl font-bold text-sky-200 uppercase tracking-tight leading-snug"
      >
        {title}
      </h2>
      <div
        class="w-16 h-1 bg-linear-to-r from-sky-500 to-blue-600 rounded-full my-4 group-hover:w-full transition-all duration-500"
      >
      </div>
      <p class="text-sm text-sky-200/60 leading-relaxed">{description}</p>
      <div class="flex items-center justify-between mt-8">
        <span
          class="text-[10px] font-medium uppercase tracking-[0.2em] text-sky-500/40"
          >Alvaro Arboleda Marulanda</span
        >
        <div
          class="flex items-center gap-1 text-sky-400 text-xs font-semibold opacity-0 group-hover:opacity-100 translate-x-4 group-hover:translate-x-0 transition-all duration-300"
        >
          <span>Read more</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="w-4 h-4"
          >
            <path
              fill-rule="evenodd"
              d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
              clip-rule="evenodd"></path>
          </svg>
        </div>
      </div>
    </div>
  </div>
</article>

<style>
  .post-card {
    background: var(--card-bg);
    border-color: var(--card-border);
  }
  .post-card:hover {
    border-color: var(--card-border-hover);
  }
</style>
