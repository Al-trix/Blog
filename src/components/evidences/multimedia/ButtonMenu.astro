---
const { title, id } = Astro.props;
---

<button
  class="btn-multimedia border border-sky-500 text-sky-500 hover:text-white hover:bg-sky-500/60 cursor-pointer active:scale-95 transition-all duration-300 shadow-lg shadow-black px-4 py-2 rounded-lg"
  data-target-id={id}>{title}</button
>

<style>
  button {
    box-shadow: inset 0 0 8px rgba(14, 165, 233, 0.4);
  }
</style>
