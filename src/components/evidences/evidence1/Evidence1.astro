---
import { Content } from './cronica.md';
import { BoltIcon } from '@heroicons/react/24/solid';
import TtitleEvidences from '../../TtitleEvidences.astro';
---

<section class="flex flex-col gap-5 mb-4 items-center justify-center px-4">
  <TtitleEvidences
    title="Cronica"
    description="This evidence is about the chronicle of Nikola Tesla"
  />
  <article
    id="chronicle-content"
    class="scroll-reveal max-w-5xl w-full relative prose prose-invert prose-headings:text-sky-200 prose-p:text-sky-200/60 prose-strong:text-sky-300 prose-h1:text-4xl prose-p:leading-relaxed bg-slate-900/40 backdrop-blur-md py-8 shadow-xl border border-sky-500/30 px-10 rounded-2xl"
  >
    <BoltIcon
      className="absolute bottom-6 -left-10 w-150 h-150 text-sky-500/10 drop-shadow-lg drop-shadow-sky-500/20 blur-2xl -z-1"
    />
    <Content />
  </article>
</section>

<style>
  /* Imagen flotante dentro del texto del markdown */
  #chronicle-content :global(img) {
    float: right;
    width: 270px;
    height: 320px;
    object-fit: cover;
    object-position: top;
    border-radius: 0.75rem;
    margin: 0.25rem 0 1.5rem 2rem;
    shape-outside: margin-box;
    box-shadow: 0 8px 32px rgba(99, 102, 241, 0.25);
    border: 1px solid rgba(99, 102, 241, 0.3);
    display: block;
  }

  /* H1 del markdown */
  #chronicle-content :global(h1) {
    font-size: 2.25rem;
    font-weight: 800;
    letter-spacing: -0.025em;
    border-bottom: 2px solid #6366f1;
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
    color: #fff;
  }

  /* Párrafos */
  #chronicle-content :global(p) {
    line-height: 1.85;
    color: #cbd5e1;
    margin-bottom: 1.25rem;
    font-size: 1rem;
  }

  /* Negritas */
  #chronicle-content :global(strong) {
    color: #818cf8;
    font-weight: 700;
  }

  /* Separador horizontal si hubiera */
  #chronicle-content :global(hr) {
    border-color: #334155;
    margin: 2rem 0;
  }

  /* Links si hubiera */
  #chronicle-content :global(a) {
    color: #6366f1;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  #chronicle-content :global(a:hover) {
    color: #a5b4fc;
  }

  @media (max-width: 640px) {
    #chronicle-content :global(img) {
      float: none;
      width: 100%;
      height: 220px;
      margin: 0 0 1.5rem 0;
    }
  }
</style>
