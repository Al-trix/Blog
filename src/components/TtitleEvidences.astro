---
const { title, description } = Astro.props;
---

<div class="flex flex-col text-center mb-10">
  <h3 class="text-3xl uppercase text-sky-500 font-medium">{title}</h3>
  <span class="bg-sky-500/20 mb-2 mt-1 h-0.5 w-20 mx-auto rounded-full flex"
  ></span>
  <p class="text-sky-200/60 text-sm">{description}</p>
</div>
